<Window x:Class="task2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator"
        Width="350" Height="500">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBox x:Name="HistoryBox"
                 IsReadOnly="True"
                 FontSize="14"
                 Margin="0,0,0,5"/>

        <TextBox x:Name="DisplayBox"
                 Grid.Row="1"
                 IsReadOnly="True"
                 FontSize="24"
                 Text="0"
                 HorizontalContentAlignment="Right"
                 Margin="0,0,0,10"/>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Content="C" Grid.Row="0" Grid.Column="0" Click="ClearAll"/>
            <Button Content="CE" Grid.Row="0" Grid.Column="1" Click="ClearEntry"/>
            <Button Content="&lt;" Grid.Row="0" Grid.Column="2" Click="Backspace"/>
            <Button Content="/" Grid.Row="0" Grid.Column="3" Click="Operation"/>

            <Button Content="7" Grid.Row="1" Grid.Column="0" Click="Digit"/>
            <Button Content="8" Grid.Row="1" Grid.Column="1" Click="Digit"/>
            <Button Content="9" Grid.Row="1" Grid.Column="2" Click="Digit"/>
            <Button Content="*" Grid.Row="1" Grid.Column="3" Click="Operation"/>

            <Button Content="4" Grid.Row="2" Grid.Column="0" Click="Digit"/>
            <Button Content="5" Grid.Row="2" Grid.Column="1" Click="Digit"/>
            <Button Content="6" Grid.Row="2" Grid.Column="2" Click="Digit"/>
            <Button Content="-" Grid.Row="2" Grid.Column="3" Click="Operation"/>

            <Button Content="1" Grid.Row="3" Grid.Column="0" Click="Digit"/>
            <Button Content="2" Grid.Row="3" Grid.Column="1" Click="Digit"/>
            <Button Content="3" Grid.Row="3" Grid.Column="2" Click="Digit"/>
            <Button Content="+" Grid.Row="3" Grid.Column="3" Click="Operation"/>

            <Button Content="0" Grid.Row="4" Grid.Column="0" Click="Digit"/>
            <Button Content="." Grid.Row="4" Grid.Column="1" Click="Dot"/>
            <Button Content="=" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Click="Equals"/>
        </Grid>
    </Grid>
</Window>
