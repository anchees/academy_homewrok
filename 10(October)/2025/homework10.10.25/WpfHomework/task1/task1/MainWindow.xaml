<Window x:Class="task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task 1 - Colors"
        Width="800" Height="450">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0">
            <WrapPanel>

                <Button Content="Navy" Margin="2" Foreground="Navy"/>
                <Button Content="Blue" Margin="2" Foreground="Blue"/>
                <Button Content="Aqua" Margin="2" Foreground="Aqua"/>
                <Button Content="Teal" Margin="2" Foreground="Teal"/>
                <Button Content="Olive" Margin="2" Foreground="Olive"/>
                <Button Content="Green" Margin="2" Foreground="Green"/>
                <Button Content="Lime" Margin="2" Foreground="Lime"/>
                <Button Content="Yellow" Margin="2" Foreground="Yellow"/>
                <Button Content="Orange" Margin="2" Foreground="Orange"/>
                <Button Content="Red" Margin="2" Foreground="Red"/>
                <Button Content="Maroon" Margin="2" Foreground="Maroon"/>
                <Button Content="Fuchsia" Margin="2" Foreground="Fuchsia"/>
                <Button Content="Purple" Margin="2" Foreground="Purple"/>
                <Button Content="Black" Margin="2" Foreground="Black"/>
                <Button Content="Silver" Margin="2" Foreground="Silver"/>
                <Button Content="Gray" Margin="2" Foreground="Gray"/>
                <Button Content="White" Margin="2" Foreground="White"/>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
