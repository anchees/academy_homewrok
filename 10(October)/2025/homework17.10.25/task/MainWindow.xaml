<Window x:Class="task.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:task.ViewModels"
        Title="ARGB Color Picker" Width="520" Height="420">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <Rectangle Height="60"
                       Fill="{Binding CurrentBrush}"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding AEnabled}" Margin="5"/>
                <TextBlock Text="A" Width="20"/>
                <Slider Minimum="0" Maximum="255"
                        Value="{Binding A}"
                        IsEnabled="{Binding AEnabled}"
                        Width="200"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding REnabled}" Margin="5"/>
                <TextBlock Text="R" Width="20"/>
                <Slider Minimum="0" Maximum="255"
                        Value="{Binding R}"
                        IsEnabled="{Binding REnabled}"
                        Width="200"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding GEnabled}" Margin="5"/>
                <TextBlock Text="G" Width="20"/>
                <Slider Minimum="0" Maximum="255"
                        Value="{Binding G}"
                        IsEnabled="{Binding GEnabled}"
                        Width="200"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding BEnabled}" Margin="5"/>
                <TextBlock Text="B" Width="20"/>
                <Slider Minimum="0" Maximum="255"
                        Value="{Binding B}"
                        IsEnabled="{Binding BEnabled}"
                        Width="200"/>
            </StackPanel>

            <Button Content="Add"
                    Command="{Binding AddCommand}"
                    Margin="0,10,0,0"
                    Height="30"/>
        </StackPanel>

        <ListBox Grid.Column="1"
                 ItemsSource="{Binding Colors}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Rectangle Width="30" Height="30"
                                   Fill="{Binding Brush}"
                                   Margin="0,0,5,0"/>

                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   Width="120"/>

                        <Button Content="Delete"
                                Command="{Binding DataContext.DeleteCommand,
                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
