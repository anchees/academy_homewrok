<Window x:Class="task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Trainer" Width="1050" Height="650"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        Loaded="Window_Loaded"
        FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Padding="10" CornerRadius="10" BorderBrush="#33000000" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Stats" FontWeight="SemiBold" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Speed: " FontSize="14"/>
                        <TextBlock x:Name="SpeedText" Text="0 cpm" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Errors: " FontSize="14"/>
                        <TextBlock x:Name="ErrorsText" Text="0" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock x:Name="StateText" Text="Press Start to begin"
                               Margin="0,6,0,0" Foreground="#FF555555"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,18,0">
                    <TextBlock Text="Difficulty settings" FontWeight="SemiBold" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
                        <TextBlock Text="Length:" VerticalAlignment="Center" Width="60"/>
                        <Slider x:Name="LenSlider" Minimum="10" Maximum="120" Value="40"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                Width="260" ValueChanged="LenSlider_ValueChanged"/>
                        <TextBlock x:Name="LenValueText" Text="40" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <CheckBox x:Name="UseCaseCheck" Content="Use letter case (Upper/Lower)"
                              Margin="0,6,0,0"/>
                    <TextBlock Text="Tip: Click window and type on your real keyboard."
                               Margin="0,6,0,0" Foreground="#FF555555"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="StartBtn" Content="Start" Width="110" Height="40"
                            Margin="0,0,10,0" Click="StartBtn_Click"/>
                    <Button x:Name="StopBtn" Content="Stop" Width="110" Height="40"
                            IsEnabled="False" Click="StopBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="10" Margin="0,10,0,10"
                CornerRadius="10" BorderBrush="#33000000" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Target:"
                           FontWeight="SemiBold" FontSize="16"/>
                <TextBlock x:Name="TargetText"
                           Grid.Row="0" Margin="70,0,0,0"
                           FontSize="16" TextWrapping="Wrap"/>

                <TextBlock Text="Typed:"
                           Grid.Row="1" Margin="0,10,0,0"
                           FontWeight="SemiBold" FontSize="16"/>
                <TextBlock x:Name="TypedText"
                           Grid.Row="1" Margin="70,10,0,0"
                           FontSize="16" TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="12" CornerRadius="10"
                BorderBrush="#33000000" BorderThickness="1">
            <StackPanel x:Name="KeyboardPanel" Orientation="Vertical" />
        </Border>
    </Grid>
</Window>
